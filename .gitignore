# ホームディレクトリ全体を無視して、必要なファイルだけを指定する
*

# 以下のファイル・フォルダだけをGitHubに含める（!で除外から外す）
!.gitignore
!*.py
!*.md
!*.json
!*.jsx
!*.png
!*.js
!ronin_images/
!ronin_images/*.png
!.github/
!.github/workflows/
!.github/workflows/*.yml

# 整理後のフォルダを追跡対象に含める
!ronin/
!ronin/fonts/
!ronin/fonts/*
!ronin/ronin_images/
!ronin/ronin_images/*.png
!skin/
!skin/skin_images/
!skin/skin_images/*.png
!skin/skin_images/*.jpg
!skin/skin_instagram_images/
!skin/skin_instagram_images/*.png
!linkedin/
!learning/
!docs/
!docs/superpowers/
!docs/superpowers/specs/
!docs/superpowers/specs/*.md
!docs/superpowers/plans/
!docs/superpowers/plans/*.md

# LinkedIn: Exclude credentials file（認証情報ファイルを除外）
linkedin/linkedin_config.json

# .claude/ 設定ファイルを同期する（認証情報は除く）
!.claude/
.claude/*
!.claude/settings.json
!.claude/statusline-command.sh

# APIキーなど秘密情報は絶対に除外
.env

# Pythonキャッシュは除外
__pycache__/
*.pyc
