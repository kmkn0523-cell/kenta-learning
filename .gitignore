# ホームディレクトリ全体を無視して、必要なファイルだけを指定する
*

# 以下のファイル・フォルダだけをGitHubに含める（!で除外から外す）
!.gitignore
!*.py
!*.md
!*.json
!*.jsx
!*.png
!ronin_images/
!ronin_images/*.png
!.github/
!.github/workflows/
!.github/workflows/*.yml

# .claude/ 設定ファイルを同期する（認証情報は除く）
!.claude/
.claude/*
!.claude/settings.json
!.claude/statusline-command.sh

# APIキーなど秘密情報は絶対に除外
.env

# Pythonキャッシュは除外
__pycache__/
*.pyc
