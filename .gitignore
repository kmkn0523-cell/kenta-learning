# ホームディレクトリ全体を無視して、必要なファイルだけを指定する
*

# 以下のファイル・フォルダだけをGitHubに含める（!で除外から外す）
!.gitignore
!.nojekyll
!*.py
!*.md
!note_article.html
!paid_note.html
!*.json
!*.jsx
!*.png
!*.js
!*.tsx
!*.ts
!ronin_images/
!ronin_images/*.png
!.github/
!.github/workflows/
!.github/workflows/*.yml

# 整理後のフォルダを追跡対象に含める
!ronin/
!ronin/fonts/
!ronin/fonts/*
!ronin/substack/
!ronin/substack/*.md
!ronin/ronin_images/
!ronin/ronin_images/*.png
!skin/
!skin/note_queue/
!skin/note_queue/*.md
!skin/skin_images/
!skin/skin_images/*.png
!skin/skin_images/*.jpg
!skin/skin_instagram_images/
!skin/skin_instagram_images/*.png
!skin/skin_instagram_carousels/
!skin/skin_instagram_carousels/*.png
!skin/links.html
!skin/profile/
!skin/profile/*.md
!skin/profile/*.png
!linkedin/
!learning/
!docs/
!finance_web/
!finance_web/src/
!finance_web/src/components/
!finance_web/src/components/*.tsx
!finance_web/src/hooks/
!finance_web/src/hooks/*.ts
!finance_web/src/views/
!finance_web/src/views/*.tsx
!finance_web/src/utils/
!finance_web/src/utils/*.ts
!finance_web/src/contexts/
!finance_web/src/contexts/*.ts
!finance_web/src/test/
!finance_web/src/test/components/
!finance_web/src/test/components/*.tsx
!finance_web/public/
!finance_web/docs/
finance_web/node_modules/
finance_web/dist/
finance_web/.vercel/
finance_web/.env.local
!docs/superpowers/
!docs/superpowers/specs/
!docs/superpowers/specs/*.md
!docs/superpowers/plans/
!docs/superpowers/plans/*.md
!finance_web/docs/superpowers/
!finance_web/docs/superpowers/specs/
!finance_web/docs/superpowers/specs/*.md
!finance_web/docs/superpowers/plans/
!finance_web/docs/superpowers/plans/*.md
!tests/
!tests/*.py

# LinkedIn: Exclude credentials file（認証情報ファイルを除外）
linkedin/linkedin_config.json

# .claude/ 設定ファイルを同期する（認証情報は除く）
!.claude/
.claude/*
!.claude/settings.json
!.claude/statusline-command.sh

# APIキーなど秘密情報は絶対に除外
.env

# Claude Code 設定（MCPサーバーのAPIキーが入るため絶対にコミットしない）
.claude.json

# 一時バックアップファイル（ロールバック用、ローカル保持のみ）
*.backup_*.json

# Pythonキャッシュは除外
__pycache__/
*.pyc
