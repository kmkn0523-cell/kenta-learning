{
  "permissions": {
    "allow": [
      "Bash(python3 -c ' *)",
      "mcp__claude_ai_Google_Calendar__list_events",
      "Bash(git *)",
      "Bash(python3 *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(pip install *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "rm -f ~/.claude/oauth-usage-cache.json"
          },
          {
            "type": "command",
            "command": "cd /home/kenta_kamijyo && git pull --no-rebase 2>/dev/null || true",
            "statusMessage": "GitHubから最新を取得中..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); cmd=$(echo \"$input\" | jq -r '.tool_input.command // \"\"'); if echo \"$cmd\" | grep -qE 'git (commit|push)'; then secrets=$(cd /home/kenta_kamijyo 2>/dev/null && git diff --cached 2>/dev/null | grep -E '^\\+[^+]' | grep -E '(EAAG|EAAl|ghp_|ghs_|sk-ant-api|ACCESS_TOKEN\\s*=\\s*[A-Za-z0-9]{10}|_TOKEN\\s*=\\s*[A-Za-z0-9]{20,})' || true); if [ -n \"$secrets\" ]; then echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"⚠️ シークレット検出！トークン/APIキーがコミット差分に含まれています。.envに移動してからコミットしてください。\"}}'; fi; fi",
            "if": "Bash(git *)",
            "statusMessage": "シークレットをスキャン中..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // \"\"' | grep -q '^/home/kenta_kamijyo/finance_web/' && touch /tmp/finance_web_changed 2>/dev/null || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/kenta_kamijyo/.claude/model_suggest.py"
          },
          {
            "type": "command",
            "command": "date +%s > /tmp/claude_task_start"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -c \"[console]::beep(1000,150); [console]::beep(800,150); [console]::beep(1000,150); [console]::beep(800,400)\" 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "start=$(cat /tmp/claude_task_start 2>/dev/null || echo 0); elapsed=$(( $(date +%s) - start )); [ $elapsed -ge 30 ] && powershell.exe -c \"[console]::beep(784,150); [console]::beep(659,150); [console]::beep(523,150); [console]::beep(784,400)\" 2>/dev/null || true",
            "async": true
          },
          {
            "type": "command",
            "command": "[ -f /tmp/finance_web_changed ] && rm /tmp/finance_web_changed && cd /home/kenta_kamijyo/finance_web && npx vercel --prod 2>/dev/null && echo '✅ デプロイ完了 → https://finance-web-kmkns-projects.vercel.app' || true",
            "statusMessage": "finance_webをVercelにデプロイ中..."
          },
          {
            "type": "command",
            "command": "echo '📝 TODO.md の更新を忘れずに'",
            "statusMessage": ""
          },
          {
            "type": "command",
            "command": "cd /home/kenta_kamijyo && git add . && (git diff --cached --quiet || git commit -m \"自動同期: $(date '+%Y/%m/%d %H:%M')\") && git push 2>/dev/null || true",
            "statusMessage": "GitHubに保存中..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /home/kenta_kamijyo/.claude/statusline-command.sh",
    "refreshInterval": 10
  },
  "enabledPlugins": {
    "vercel@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "last30days-skill": {
      "source": {
        "source": "github",
        "repo": "mvanhorn/last30days-skill"
      }
    }
  },
  "language": "japanese",
  "feedbackSurveyRate": 0,
  "effortLevel": "medium",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "autoCompactEnabled": true,
  "autoCompactWindow": 100000,
  "fileCheckpointingEnabled": true,
  "showTurnDuration": true,
  "agentPushNotifEnabled": true,
  "skillListingMaxDescChars": 300,
  "skillListingBudgetFraction": 0.005,
  "spinnerTipsEnabled": false,
  "verbose": false
}
