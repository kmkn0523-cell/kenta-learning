{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "rm -f ~/.claude/oauth-usage-cache.json"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // \"\"' | grep -q '^/home/kenta_kamijyo/finance_web/' && touch /tmp/finance_web_changed 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -f /tmp/finance_web_changed ] && rm /tmp/finance_web_changed && cd /home/kenta_kamijyo/finance_web && npx vercel --prod 2>/dev/null || true",
            "statusMessage": "finance_webをVercelにデプロイ中..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /home/kenta_kamijyo/.claude/statusline-command.sh",
    "refreshInterval": 10
  },
  "enabledPlugins": {
    "vercel@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "last30days-skill": {
      "source": {
        "source": "github",
        "repo": "mvanhorn/last30days-skill"
      }
    }
  },
  "language": "japanese",
  "effortLevel": "medium",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "agentPushNotifEnabled": true
}
